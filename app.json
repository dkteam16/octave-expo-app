{
  "expo": {
    "name": "Octave Mettle",
    "slug": "octave-mettle-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#ffffff",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.co.octave.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSCameraUsageDescription": "Octave Mettle uses your camera for product try-on and barcode scanning features.",
        "NSPhotoLibraryUsageDescription": "Octave Mettle needs access to your photos to let you upload images.",
        "NSFaceIDUsageDescription": "Use Face ID to securely log in to your Octave Mettle account."
      }
    },
    "android": {
      "package": "in.co.octave.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE-WITH-YOUR-EAS-PROJECT-ID"
      }
    }
  }
}